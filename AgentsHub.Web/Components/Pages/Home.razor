@page "/"
@layout AgentsHub.Web.Components.Layout.SimpleLayout

<PageTitle>Home</PageTitle>

<!-- CONVERSATION SIDEBAR -->
<aside class="hidden md:flex w-72 flex-shrink-0 bg-surface-900 border-r border-surface-700/50 flex-col">
    <div class="px-3 py-3">
        <button class="w-full flex items-center gap-2 px-4 py-2.5 rounded-lg bg-accent/10 hover:bg-accent/20 text-accent text-sm font-medium transition-colors border border-accent/20">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
            New Chat
        </button>
    </div>
    <div class="flex-1 overflow-y-auto px-3 space-y-0.5">
        <p class="px-3 py-2 text-xs font-medium text-surface-500 uppercase tracking-wider">Today</p>
        <a href="#" class="conversation-active flex items-center gap-3 px-3 py-2.5 rounded-r-lg">
            <div class="w-6 h-6 rounded-full bg-emerald-500/20 flex items-center justify-center flex-shrink-0"><span class="text-xs text-emerald-400">S</span></div>
            <div class="min-w-0 flex-1"><p class="text-sm text-white truncate">Setting up Tailwind in Blazor</p><p class="text-xs text-surface-500 truncate">Strategy Agent · 3m ago</p></div>
        </a>
        <a href="#" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-surface-800/60 transition-colors group">
            <div class="w-6 h-6 rounded-full bg-teal-500/20 flex items-center justify-center flex-shrink-0"><span class="text-xs text-teal-400">C</span></div>
            <div class="min-w-0 flex-1"><p class="text-sm text-surface-300 truncate group-hover:text-white transition-colors">Code review: EF Core config</p><p class="text-xs text-surface-500 truncate">Code Reviewer · 1h ago</p></div>
        </a>
        <p class="px-3 py-2 mt-3 text-xs font-medium text-surface-500 uppercase tracking-wider">Yesterday</p>
        <a href="#" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-surface-800/60 transition-colors group">
            <div class="w-6 h-6 rounded-full bg-amber-500/20 flex items-center justify-center flex-shrink-0"><span class="text-xs text-amber-400">B</span></div>
            <div class="min-w-0 flex-1"><p class="text-sm text-surface-300 truncate group-hover:text-white transition-colors">Brand positioning for SaaS launch</p><p class="text-xs text-surface-500 truncate">Brand Manager · 18h ago</p></div>
        </a>
        <a href="#" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-surface-800/60 transition-colors group">
            <div class="w-6 h-6 rounded-full bg-orange-500/20 flex items-center justify-center flex-shrink-0"><span class="text-xs text-orange-400">L</span></div>
            <div class="min-w-0 flex-1"><p class="text-sm text-surface-300 truncate group-hover:text-white transition-colors">Legal review: vendor contract</p><p class="text-xs text-surface-500 truncate">Legal Advisor · 22h ago</p></div>
        </a>
        <a href="#" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-surface-800/60 transition-colors group">
            <div class="w-6 h-6 rounded-full bg-lime-500/20 flex items-center justify-center flex-shrink-0"><span class="text-xs text-lime-400">A</span></div>
            <div class="min-w-0 flex-1"><p class="text-sm text-surface-300 truncate group-hover:text-white transition-colors">Database schema design review</p><p class="text-xs text-surface-500 truncate">Architect · 1d ago</p></div>
        </a>
    </div>
    <div class="px-3 py-3 border-t border-surface-700/50">
        <div class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-surface-800/60 transition-colors cursor-pointer">
            <div class="w-8 h-8 rounded-full bg-surface-700 flex items-center justify-center"><span class="text-xs font-medium text-surface-300">AJ</span></div>
            <div class="flex-1 min-w-0"><p class="text-sm text-surface-300">Andrew Judd</p></div>
            <svg class="w-4 h-4 text-surface-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
        </div>
    </div>
</aside>

<!-- MAIN CHAT AREA -->
<main class="flex-1 flex flex-col">
    <!-- Chat Header -->
    <header class="flex items-center justify-between px-3 md:px-6 py-3.5 border-b border-surface-700/50 bg-surface-900/50 backdrop-blur-sm">
        <div class="flex items-center gap-3">
            <button class="md:hidden p-1.5 rounded-lg hover:bg-surface-700/60 text-surface-400 hover:text-surface-200 transition-colors">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
            </button>
            <div class="w-8 h-8 rounded-full bg-emerald-500/20 flex items-center justify-center"><span class="text-sm text-emerald-400 font-medium">S</span></div>
            <div><h1 class="text-sm font-semibold text-white">Strategy Agent</h1><p class="text-xs text-surface-500">qwen2.5:14b · 0.7 temp</p></div>
        </div>
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-success/10 text-success text-xs font-medium"><span class="w-1.5 h-1.5 rounded-full bg-success animate-pulse"></span>Connected</span>
    </header>

    <!-- Messages -->
    <div class="flex-1 overflow-y-auto px-3 md:px-6 py-4 md:py-6 space-y-6">
        <div class="flex justify-center message-enter">
            <div class="px-4 py-2 rounded-full bg-surface-800/60 border border-surface-700/30 text-xs text-surface-400">
                Conversation started with <span class="text-accent font-medium">Strategy Agent</span>
            </div>
        </div>

        <!-- User message -->
        <div class="flex justify-end message-enter">
            <div class="max-w-2xl">
                <div class="bg-surface-700/60 rounded-2xl rounded-tr-md px-5 py-3.5">
                    <p class="text-sm text-surface-100 leading-relaxed">How should I structure the Tailwind CSS setup in a Blazor Server project? I want it to auto-build when I run dotnet build.</p>
                </div>
                <p class="text-xs text-surface-600 mt-1.5 text-right">2:34 PM</p>
            </div>
        </div>

        <!-- Assistant message -->
        <div class="flex gap-3 message-enter">
            <div class="w-7 h-7 rounded-full bg-emerald-500/20 flex items-center justify-center flex-shrink-0 mt-1"><span class="text-xs text-emerald-400 font-medium">S</span></div>
            <div class="max-w-2xl">
                <div class="bg-surface-800/40 rounded-2xl rounded-tl-md px-5 py-3.5 border border-surface-700/20">
                    <div class="text-sm text-surface-200 leading-relaxed space-y-3">
                        <p>There are a few approaches, but the cleanest for your setup is wiring the Tailwind CLI directly into MSBuild. Here's the strategy:</p>
                        <p><strong class="text-white">1. Install via npm</strong> in your Web project directory. You only need two packages: <code class="font-mono text-xs bg-surface-700/60 px-1.5 py-0.5 rounded text-accent">tailwindcss</code> and <code class="font-mono text-xs bg-surface-700/60 px-1.5 py-0.5 rounded text-accent">tailwindcss/cli</code>.</p>
                        <p><strong class="text-white">2. Add a build target</strong> to your <code class="font-mono text-xs bg-surface-700/60 px-1.5 py-0.5 rounded text-accent">.csproj</code> file using <code class="font-mono text-xs bg-surface-700/60 px-1.5 py-0.5 rounded text-accent">BeforeTargets="Build"</code>.</p>
                        <div class="bg-surface-900/80 rounded-lg p-4 font-mono text-xs border border-surface-700/30">
                            <pre class="text-surface-300"><span class="text-amber-400">&lt;Target</span> <span class="text-lime-400">Name</span>=<span class="text-emerald-400">"TailwindBuild"</span>
    <span class="text-lime-400">BeforeTargets</span>=<span class="text-emerald-400">"Build"</span><span class="text-amber-400">&gt;</span>
<span class="text-amber-400">&lt;Exec</span> <span class="text-lime-400">Command</span>=<span class="text-emerald-400">"npx tailwindcss/cli ..."</span> <span class="text-amber-400">/&gt;</span>
<span class="text-amber-400">&lt;/Target&gt;</span></pre>
                        </div>
                        <p><strong class="text-white">3. For development</strong>, run the CLI in watch mode in a separate terminal. This gives you instant CSS updates without waiting for a full rebuild.</p>
                    </div>
                </div>
                <p class="text-xs text-surface-600 mt-1.5">2:34 PM · 847 tokens</p>
            </div>
        </div>

        <!-- User message -->
        <div class="flex justify-end message-enter">
            <div class="max-w-2xl">
                <div class="bg-surface-700/60 rounded-2xl rounded-tr-md px-5 py-3.5">
                    <p class="text-sm text-surface-100 leading-relaxed">What about the content paths? How does Tailwind v4 know which files to scan?</p>
                </div>
                <p class="text-xs text-surface-600 mt-1.5 text-right">2:35 PM</p>
            </div>
        </div>

        <!-- Streaming assistant message -->
        <div class="flex gap-3 message-enter">
            <div class="w-7 h-7 rounded-full bg-emerald-500/20 flex items-center justify-center flex-shrink-0 mt-1"><span class="text-xs text-emerald-400 font-medium">S</span></div>
            <div class="max-w-2xl">
                <div class="bg-surface-800/40 rounded-2xl rounded-tl-md px-5 py-3.5 border border-surface-700/20">
                    <div class="text-sm text-surface-200 leading-relaxed">
                        <p>Tailwind v4 auto-detects content sources by scanning your project directory. It uses heuristics to find common file types like <code class="font-mono text-xs bg-surface-700/60 px-1.5 py-0.5 rounded text-accent">.html</code>, <code class="font-mono text-xs bg-surface-700/60 px-1.5 py-0.5 rounded text-accent">.js</code>, and others. However, it might not automatically pick up <code class="font-mono text-xs bg-surface-700/60 px-1.5 py-0.5 rounded text-accent">.razor</code> files since<span class="streaming-cursor"></span></p>
                    </div>
                </div>
                <div class="flex items-center gap-2 mt-1.5">
                    <div class="flex items-center gap-1">
                        <span class="w-1 h-1 rounded-full bg-accent animate-pulse"></span>
                        <span class="w-1 h-1 rounded-full bg-accent animate-pulse" style="animation-delay:0.2s"></span>
                        <span class="w-1 h-1 rounded-full bg-accent animate-pulse" style="animation-delay:0.4s"></span>
                    </div>
                    <p class="text-xs text-surface-600">Generating...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Input -->
    <div class="px-3 md:px-6 py-3 md:py-4 border-t border-surface-700/50 bg-surface-900/30 backdrop-blur-sm">
        <div class="max-w-3xl mx-auto">
            <div class="flex items-end gap-3 bg-surface-800/60 rounded-xl border border-surface-700/40 focus-within:border-accent/40 transition-colors p-3">
                <button class="p-1.5 rounded-lg hover:bg-surface-700/60 text-surface-500 hover:text-surface-300 transition-colors flex-shrink-0">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m18.375 12.739-7.693 7.693a4.5 4.5 0 0 1-6.364-6.364l10.94-10.94A3 3 0 1 1 19.5 7.372L8.552 18.32m.009-.01-.01.01m5.699-9.941-7.81 7.81a1.5 1.5 0 0 0 2.112 2.13"/></svg>
                </button>
                <textarea class="chat-input flex-1 bg-transparent text-sm text-surface-100 placeholder-surface-500 resize-none max-h-32" placeholder="Message Strategy Agent..." rows="1"></textarea>
                <button class="p-2 rounded-lg bg-accent hover:bg-accent/80 text-surface-950 transition-colors flex-shrink-0">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5"/></svg>
                </button>
            </div>
            <p class="text-center text-xs text-surface-600 mt-2">AgentHub can make mistakes. Verify important information.</p>
        </div>
    </div>
</main>